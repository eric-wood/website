{% extends "layout" %}
{% set active_page = 'photos' %}
{% block title %}Photos{% endblock %}
{% block head %}<link rel="stylesheet" href="/photos/assets/photos/index.css" />{% endblock %}
{% block body %}
  <div class="photos__layout">
    <div class="photos__mobile-nav">
      <button type="button" class="mobile-nav-toggle">Filter</button>
      <a href="?{{ sort_link }}" class="sort">
        Sort {% if sort_dir == "asc" -%}↑{% else -%}↓{% endif %}
      </a>
    </div>
    <div class="photos__container">
      <div class="photos">
        {% for photo in photos %}
          <a
            href="/photos/{{ photo.id }}"
            id="{{ photo.id }}"
            data-width="{{ photo.width }}"
            data-height="{{ photo.height }}"
          >
            <img
            {% if loop.index < 6 %}
              fetchpriority="high"
            {% endif %}
              src="/photos/thumbnails/{{ photo.id }}.webp"
            >
          </a>
        {% endfor %}
      </div>
      {% if pagination.num_pages > 1 %}
        <nav class="pagination">
          {% if pagination.prev_query %}
            <a href="?{{ pagination.prev_query }}" class="arrow">←</a>
          {% else %}
            <span class="arrow">←</span>
          {% endif %}
          <span>
            <span class="page">
              <label for="page_number">{{ pagination.page }}</label>
              <select id="page_number">
                {% for i in range(pagination.num_pages) %}
                  <option
                    value="{{ i + 1 }}"
                    {% if pagination.page == i + 1 %}
                      selected="selected"
                    {% endif %}
                  >
                    {{ i + 1 }}
                  </option>
                {% endfor %}
              </select>
            </span>
            /
            {{ pagination.num_pages }}
          </span>
          {% if pagination.next_query %}
            <a href="?{{ pagination.next_query }}" class="arrow">→</a>
          {% else %}
            <span class="arrow">→</span>
          {% endif %}
        </nav>
      {% endif %}
    </div>
    <nav class="photos__nav">
      <ul>
        {% for tag in current_tags %}
          <li class="selected">
            {{ tag.name }}
            <a href="?{{ tag.action }}">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                <use xlink:href="#close-icon" />
              </svg>
            </a>
          </li>
        {% endfor %}
        {% for selectable in tags %}
          <li>
            <a href="?{{ selectable.action }}">{{ selectable.tag.name }} ({{ selectable.tag.count }})</a>
          </li>
        {% endfor %}
      </ul>
      <p>
        Sort:
          <a href="?{{ sort_link }}">
            {% if sort_dir == "asc" -%}↑{% else -%}↓{% endif %}
          </a>
      </p>
      <button type="button" class="close mobile-nav-toggle">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
          <use xlink:href="#close-icon" />
        </svg>
      </button>
    </nav>
  </div>
  <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" style="display: none">
    <defs>
      <path id="close-icon" d="M20.7457 3.32851C20.3552 2.93798 19.722 2.93798 19.3315 3.32851L12.0371 10.6229L4.74275 3.32851C4.35223 2.93798 3.71906 2.93798 3.32854 3.32851C2.93801 3.71903 2.93801 4.3522 3.32854 4.74272L10.6229 12.0371L3.32856 19.3314C2.93803 19.722 2.93803 20.3551 3.32856 20.7457C3.71908 21.1362 4.35225 21.1362 4.74277 20.7457L12.0371 13.4513L19.3315 20.7457C19.722 21.1362 20.3552 21.1362 20.7457 20.7457C21.1362 20.3551 21.1362 19.722 20.7457 19.3315L13.4513 12.0371L20.7457 4.74272C21.1362 4.3522 21.1362 3.71903 20.7457 3.32851Z" fill="currentColor"/>
    </defs>
  </svg>
  <script src="/photos/assets/photos/index.js" type="text/javascript"></script>
{% endblock %}
