<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1.0">
    <meta name="description" content="{{ meta_description|default("Eric, online") }}">
    {% if meta_image is defined %}
      <meta property="og:image" content="{{ meta_image }}">
    {% endif %}
    <meta property="og:type" content="website">
    <link rel="stylesheet" href="/photos/assets/fonts/inter/inter.css">
    <style type="text/css">
      :root { font-family: 'Inter', serif; }
        @supports (font-variation-settings: normal) {
          :root { font-family: 'InterVariable', serif; }
        }
    </style>
    <style type="text/css">
      * {
        box-sizing: border-box;
      }

      html, body {
        height: 100%;
        min-height: 100%;
        margin: 0;
        padding: 0;
      }

      body {
        display: flex;
        flex-direction: column;
        align-items: center;
      }

      .container {
        width: 100%;
        max-width: 3000px;
        overflow: auto;
      }

      header {
        display: flex;
        font-size: 16pt;
        width: 100%;
        border-bottom: solid black 3px;
      }

      header h1 {
        text-transform: uppercase;
        font-weight: 900;
        margin: 0;
        letter-spacing: 3px;
        padding: 10px 30px;
        border-right: solid black 3px;
      }

      header nav ul {
        display: flex;
        height: 100%;
        list-style-type: none;
        margin: 0;
        padding: 0;
      }

      header nav ul a {
        display: flex;
        align-items: center;
        height: 100%;
        text-decoration: none;
        color: black;
        padding: 0 30px;
      }

      header nav ul a.active, header nav ul a:hover {
        background-color: black;
        color: white;
      }

      @media (max-width: 850px) {
        header {
          flex-direction: column;
        }

        header nav ul {
          flex-direction: column;
        }
      }
    </style>
    <title>{% block title %}{% endblock %}</title>
    {% block head %}{% endblock %}
  </head>
  <body>
    <div class="container">
      <header>
      <div>
        <h1>Eric Wood</h1>
        </div>
        <nav>
          <ul>
            {% set active_page = active_page|default('') %}
            {% for link in nav_links %}
              <li>
                <a
                  href="{{ link.href }}"
                  {% if active_page == link.id %}
                  class="active"
                  {% endif %}
                >{{ link.label }}</a>
              </li>
            {% endfor %}
          </ul>
        </nav>
      </header>
      {% block body %}{% endblock %}
    </div>
    <script src="/photos/assets/app.js" type="text/javascript"></script>
  </body>
</html>
