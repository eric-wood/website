{% extends "layout" %}
{% block title %}Photos{% endblock %}
{% block body %}
  <nav>
  {{ dir }}
    <ul>
    {% if current_tag %}
      <li>{{ current_tag }} <a href="/">🅇</a></li>
    {% endif %}
    {% for tag in tags %}
      <li>
        {% if current_tag == tag.name -%}
          {{ tag.name }} ({{ tag.count }})
        {% else -%}
          <a href="?tag={{ tag.name }}">
            {{ tag.name }} ({{ tag.count }})
          </a>
        {% endif %}
      </li>
    {% endfor %}
    </ul>
    <p>
      Sort: 
      {% if sort_dir == "asc" -%}
        <a href="/?dir=desc">↑</a>
      {% else -%}
        <a href="/?dir=asc">↓</a>
      {% endif %}
    </p>
    <select id="sort" name="sort">
      {% for field in sort_fields %}
        <option value="{{ field }}" {% if field == sort_field -%}selected="true"{% endif %}>{{ field }}</option>
      {% endfor %}
    </select>
    </select>
  </nav>
  <div class="photos">
    {% for photo in photos %}
      <a href="/{{ photo.id }}">
        <p><time datetime="{{ photo.taken_at }}">{{ photo.taken_at }}</time></p>
        <img
          style="aspect-ratio: {{ photo.width }} / {{ photo.height }}"
          src="/thumbnails/{{ photo.id }}.webp"
        >
      </a>
    {% endfor %}
  </div>

  <ul class="pagination">
    {% if pagination.page > 1 %}
      <a href="?page={{ pagination.page - 1 }}">←</a>
    {% endif %}
    {% for i in range(1, pagination.num_pages+1) %}
      <li>
      {% if pagination.page == i %}
        {{ i }}
      {% else %}
        <a href="?page={{ i }}">{{ i }}</a>
      {% endif %}
      </li>
    {% endfor %}
    {% if pagination.page != pagination.num_pages %}
      <a href="?page={{ pagination.page + 1 }}">→</a>
    {% endif %}
  </ul>
{% endblock %}
