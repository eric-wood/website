{% set themes = [
  ("black", "white"),
  ("firebrick", "whitesmoke"),
  ("lightgreen", "darkslategray"),
  ("pink", "rebeccapurple"),
  ("midnightblue", "aliceblue"),
] %}
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1.0">
    <link rel="apple-touch-icon" sizes="180x180"    href="{{ assets_path("apple-touch-icon.png") }}">
    <link rel="icon" type="image/png" sizes="32x32" href="{{ assets_path("favicon-32x32.png") }}">
    <link rel="icon" type="image/png" sizes="16x16" href="{{ assets_path("favicon-16x16.png") }}">
    <link rel="manifest" href="{{ assets_path("site.webmanifest") }}">
    <meta name="description" content="{{ meta_description|default("Eric, online") }}">
    {% if meta_image is defined %}
      <meta property="og:image" content="{{ meta_image }}">
      <meta name="twitter:card" content="summary_large_image">
      <meta name="twitter:image:src" content="{{ meta_image }}">
      <meta property="og:image:height" content="500">
    {% endif %}
    <meta property="og:type" content="website">
    <link rel="stylesheet" href="{{ assets_path("fonts/inter/inter.css") }}">
    <style type="text/css">
      :root { font-family: 'Inter', serif; }
        @supports (font-variation-settings: normal) {
          :root { font-family: 'InterVariable', serif; }
        }
    </style>

    {{ inline_style("src/styles/app.css") }}
    <title>{% block title %}{% endblock %}</title>
    {% block head %}{% endblock %}
  </head>
  <body>
    <div class="container">
      <div>
        <header>
          <div class="title-container">
            <a href="/" class="home">
              <h1>Eric Wood</h1>
            </a>
            <button type="button" onclick="toggleMenu()" role="menu">
              <svg xmlns="http://www.w3.org/2000/svg" xml:space="preserve" viewBox="0 0 12 12"><g fill="currentColor"><path d="M.5 5.5h11v1H.5zM.5 2.5h11v1H.5zM.5 8.5h11v1H.5z"/></g></svg>
            </button>
          </div>
          <nav class="hidden" role="menu">
            <ul>
              {% set active_page = active_page|default('') %}
              {% for link in nav_links %}
                <li>
                  <a
                    href="{{ link.href }}"
                    {% if active_page == link.id %}
                    class="active"
                    {% endif %}
                    role="menuitem"
                  >{{ link.label }}</a>
                </li>
              {% endfor %}
            </ul>
          </nav>
        </header>
        <main role="main">
          {% block body %}{% endblock %}
        </main>
      </div>
      <footer>
        <div class="footer__links">
          <div>
            <h4>Site</h4>
            <ul>
              {% for link in nav_links %}
                <li>
                  <a href="{{ link.href }}">{{ link.label }}</a>
                </li>
              {% endfor %}
            </ul>
          </div>
          <div>
            <h4>Links</h4>
            <ul>
              <li><a href="mailto:eric@ericwood.org">Email</a></li>
              <li><a href="/resume">Resume</a></li>
              <li><a href="https://github.com/eric-wood">Github</a></li>
              <li><a href="https://bsky.app/profile/ericwood.org">BlueSky</a></li>
              <li><a href="https://www.linkedin.com/in/ericwoodtx/">LinkedIn</a></li>
            </ul>
          </div>
          <div>
            <h4>Meta</h4>
            <ul>
              <li>
                <div class="theme-swatches">
                  Theme
                  {% for theme in themes %}
                    <button
                      type="button"
                      class="theme-swatch"
                      data-foreground="{{ theme[0] }}"
                      data-background="{{ theme[1] }}"
                      style="background-color: {{ theme[0] }}"
                      onclick="setTheme(this)"
                      aria-label="Theme {{ theme[0] }}"
                    >
                    </button>
                  {% endfor %}
                </div>
              </li>
              <li><a href="/projects/website">How it works</a></li>
              <li><a href="https://github.com/eric-wood/website">View source</a></li>
              <li><a href="/info">Server info</a></li>
            </ul>
          </div>
        </div>
        <div class="footer__subtext">
          <div>© Eric Wood {{ year() }}</div>
          <div>Rendered {{ timestamp() }}</div>
        </div>
      </footer>
    </div>

    {{ inline_script("assets/app.js") }}
  </body>
</html>
