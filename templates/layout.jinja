<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1.0">
    <link rel="apple-touch-icon" sizes="180x180"    href="{{ assets_path("apple-touch-icon.png") }}">
    <link rel="icon" type="image/png" sizes="32x32" href="{{ assets_path("favicon-32x32.png") }}">
    <link rel="icon" type="image/png" sizes="16x16" href="{{ assets_path("favicon-16x16.png") }}">
    <link rel="manifest" href="{{ assets_path("site.webmanifest") }}">
    <meta name="description" content="{{ meta_description|default("Eric, online") }}">
    {% if meta_image is defined %}
      <meta property="og:image" content="{{ meta_image }}">
      <meta name="twitter:card" content="summary_large_image">
      <meta name="twitter:image:src" content="{{ meta_image }}">
      <meta property="og:image:height" content="500">
    {% endif %}
    <meta property="og:type" content="website">
    <link rel="stylesheet" href="{{ assets_path("fonts/inter/inter.css") }}">
    <style type="text/css">
      :root { font-family: 'Inter', serif; }
        @supports (font-variation-settings: normal) {
          :root { font-family: 'InterVariable', serif; }
        }
    </style>
    <style type="text/css">
      :root {
        --foreground: black;
        --background: white;
        --half: color-mix(in srgb, var(--foreground) 50%, transparent);
        --light: color-mix(in srgb, var(--foreground) 10%, transparent);
      }

      * {
        box-sizing: border-box;
      }

      html, body {
        height: 100%;
        min-height: 100%;
        margin: 0;
        padding: 0;
        color: var(--foreground);
        background-color: var(--background);
      }

      body {
        display: flex;
        flex-direction: column;
        align-items: center;
        height: 100%;
      }

      .container {
        width: 100%;
        height: 100%;
        max-width: 3000px;
        overflow: auto;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
      }

      header {
        display: flex;
        font-size: 16pt;
        width: 100%;
        border-bottom: solid var(--foreground) 3px;
      }

      header h1 {
        color: var(--foreground);
        text-transform: uppercase;
        font-weight: 900;
        margin: 0;
        letter-spacing: 3px;
        padding: 10px 30px;
        border-right: solid var(--foreground) 3px;
      }

      header nav ul {
        display: flex;
        height: 100%;
        list-style-type: none;
        margin: 0;
        padding: 0;
      }

      header nav ul a {
        display: flex;
        align-items: center;
        height: 100%;
        text-decoration: none;
        color: var(--foreground);
        padding: 0 30px;
      }

      header nav ul a.active, header nav ul a:hover {
        background-color: var(--foreground);
        color: var(--background);
      }

      @media (max-width: 850px) {
        header {
          flex-direction: column;
        }

        header nav ul {
          flex-direction: column;
        }
      }

      footer {
        margin-top: 30px;
        padding: 30px;
        color: var(--half);
      }
    </style>
    <title>{% block title %}{% endblock %}</title>
    {% block head %}{% endblock %}
  </head>
  <body>
    <div class="container">
      <div>
        <header>
          <div>
            <h1>Eric Wood</h1>
          </div>
          <nav>
            <ul>
              {% set active_page = active_page|default('') %}
              {% for link in nav_links %}
                <li>
                  <a
                    href="{{ link.href }}"
                    {% if active_page == link.id %}
                    class="active"
                    {% endif %}
                  >{{ link.label }}</a>
                </li>
              {% endfor %}
            </ul>
          </nav>
        </header>
        {% block body %}{% endblock %}
      </div>
      <footer>
        © Eric Wood {{ year() }}
      </footer>
    </div>

    {{ inline_script("assets/app.js") }}
  </body>
</html>
