<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1.0">
    <link re="stylesheet" href="/photos/assets/fonts/inter/inter.css">
    <style type="text/css">
      :root { font-family: 'Inter', sans-serif; }
        @supports (font-variation-settings: normal) {
          :root { font-family: 'InterVariable', sans-serif; }
        }
    </style>
    <style type="text/css">
      * {
        box-sizing: border-box;
      }

      html, body {
        height: 100%;
        min-height: 100%;
        margin: 0;
        padding: 0;
      }

      body {
        display: flex;
        flex-direction: column;
        align-items: center;
      }

      .container {
        width: 100%;
        max-width: 3000px;
        overflow: auto;
      }

      header {
        display: flex;
        align-items: center;
        gap: 30px;
        font-size: 16pt;
        width: 100%;
        border-bottom: solid black 3px;
      }

      header h1 {
        text-transform: uppercase;
        font-weight: 900;
        margin: 0;
        letter-spacing: 3px;
        padding: 10px 30px;
        border-right: solid black 3px;
      }

      header nav ul {
        display: flex;
        gap: 30px;
        list-style-type: none;
        margin: 0;
        padding: 0;
      }

      header nav ul a {
        text-decoration: none;
        color: black;
      }
    </style>
    <title>
      {% block title %}{% endblock %}
    </title>
    {% block head %}{% endblock %}
  </head>
  <body>
    <div class="container">
      <header>
        <h1>Eric Wood</h1>
        <nav>
          <ul>
            <li><a href="/photos">Photos</a></li>
            <li><a href="">Music</a></li>
            <li><a href="">Blog</a></li>
            <li><a href="">Projects</a></li>
          </ul>
        </nav>
      </header>
      {% block body %}{% endblock %}
    </div>
    <script src="/photos/assets/app.js" type="text/javascript"></script>
  </body>
</html>
